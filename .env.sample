# Copy this file to .env.local and fill values (DO NOT commit .env.local)

# ── Glific credentials ────────────────────────────────────────────────────────
GLIFIC_URL=
GLIFIC_TOKEN=
GLIFIC_ACCESS_TOKEN=
GLIFIC_REFRESH_TOKEN=
GLIFIC_TOKEN_EXPIRY=
GLIFIC_PHONE_NUMBER=
WEBHOOK_SECRET=

# ── LMS credentials ───────────────────────────────────────────────────────────
LMS_BASE_URL=
LMS_API_KEY=
LMS_POLLING_ENABLED=1

# ── Test / dev settings ───────────────────────────────────────────────────────
GLIFIC_TEST_PHONE=
GLIFIC_TEST_MESSAGE=Test message from TAP Buddy dev
DRY_RUN=1  # set to 0 to allow live send