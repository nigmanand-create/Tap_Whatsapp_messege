### Environment sample for TAP Buddy integrations
# Copy to .env.local and fill with real credentials. Do NOT commit .env.local.

# LMS
LMS_BASE_URL=https://lms.example.org
LMS_API_KEY=<api_key>:<api_secret>
LMS_POLLING_ENABLED=0

# Glific
GLIFIC_BASE_URL=https://api.tap.glific.com
GLIFIC_ACCESS_TOKEN=
GLIFIC_REFRESH_TOKEN=
GLIFIC_TOKEN_EXPIRY=
GLIFIC_PHONE_NUMBER=

# Other integrations
# Add any other secrets here and reference via os.environ.get in code
