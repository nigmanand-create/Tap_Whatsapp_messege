{
 "doctype": "DocType",
 "name": "LMS Trigger Log",
 "module": "TAP Buddy",
 "autoname": "LMS-.YYYY.-.#####",
 "title_field": "event_type",
 "search_fields": "event_id,event_type,status",
 "custom": 0,
 "sort_field": "creation",
 "sort_order": "DESC",

 "fields": [
  {
   "fieldname": "event_id",
   "label": "Event ID",
   "fieldtype": "Data",
   "in_list_view": 1
  },
  {
   "fieldname": "event_type",
   "label": "Event Type",
   "fieldtype": "Data",
   "in_list_view": 1
  },
  {
   "fieldname": "status",
   "label": "Status",
   "fieldtype": "Select",
   "options": "Pending\nProcessed\nFailed\nSkipped",
   "default": "Pending",
   "in_list_view": 1
  },
  {
   "fieldname": "mapping",
   "label": "Mapping",
   "fieldtype": "Link",
   "options": "LMS Event Mapping"
  },
  {
   "fieldname": "campaign",
   "label": "Campaign",
   "fieldtype": "Link",
   "options": "TAP Campaign"
  },
  {
   "fieldname": "source",
   "label": "Source",
   "fieldtype": "Data",
   "default": "lms"
  },
  {
   "fieldname": "received_at",
   "label": "Received At",
   "fieldtype": "Datetime",
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "processed_at",
   "label": "Processed At",
   "fieldtype": "Datetime",
   "read_only": 1
  },
  {
   "fieldname": "signature",
   "label": "Signature",
   "fieldtype": "Data",
   "read_only": 1
  },
  {
   "fieldname": "error",
   "label": "Error",
   "fieldtype": "Small Text",
   "read_only": 1
  },
  {
   "fieldname": "payload",
   "label": "Payload",
   "fieldtype": "Code",
   "options": "JSON",
   "read_only": 1
  }
 ],

 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1
  }
 ]
}
